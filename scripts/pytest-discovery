#!/bin/bash
set -eo pipefail
# Run pytest in collection-only mode to verify test discovery works
# without actually executing any tests.
# Uses --all-packages to get deps from all workspace members.
# Excludes samples/ (standalone example projects) and github_datasets/ (yanked dep).
uv run --all-packages pytest --collect-only -q \
  --ignore=samples \
  --ignore=github_datasets \
  2>&1 | tail -5
