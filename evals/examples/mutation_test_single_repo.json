{
  // Mutation eval: 2 repos (flask, requests) x claude-opus x all 20 broken branches
  "description": "Mutation eval: flask + requests with all broken branches, claude-opus.",
  "repo_list_path": "evals/examples/repos_with_mutations.jsonl",
  "limit_to_first_n_repos": 2,
  "s3_output_prefix": "s3://int8-datasets/keystone/evals/mutation-smoke-test/",
  "s3_repo_cache_prefix": "s3://int8-datasets/keystone/evals/repo-tarballs-with-mutations/",
  "max_concurrent": 2,
  "configs": [
    {
      "name": "claude-opus",
      "keystone_config": {
        "agent_config": {
          "provider": "claude",
          "guardrail": true,
          "use_agents_md": true,
          "agent_in_modal": true,
          "model": "claude-opus-4-6",
          "claude_reasoning_level": "medium",
          "max_budget_usd": 10.0,
          "agent_time_limit_seconds": 1800,
          "cost_poll_interval_seconds": 30
        }
      },
      "trials_per_repo": 1
    }
  ]
}
